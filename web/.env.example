# ═══════════════════════════════════════════════════════════════════
# Intelligence RM Platform — Environment Configuration Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# SERVER
# ───────────────────────────────────────────────────────────────────
PORT=9017
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=8h

# ───────────────────────────────────────────────────────────────────
# ORACLE AUTONOMOUS DATABASE 26ai
# ───────────────────────────────────────────────────────────────────
# Path to the unzipped Oracle Wallet directory
DB_WALLET_DIR=/path/to/wallet

# Wallet password (leave blank if not encrypted)
DB_WALLET_PASSWORD=

# Database credentials
DB_USER=
DB_PASSWORD=

# Connection string — use the alias from tnsnames.ora inside the wallet
# Typical aliases: <db-name>_high, <db-name>_medium, <db-name>_low, <db-name>_tp
DB_CONNECT_STRING=irmdb_tp

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1

# ───────────────────────────────────────────────────────────────────
# OCI CREDENTIALS (API Key Authentication)
# ───────────────────────────────────────────────────────────────────
OCI_TENANCY_ID=ocid1.tenancy.oc1..aaaa...
OCI_USER_ID=ocid1.user.oc1..aaaa...
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
# Path to your OCI API private key PEM file
OCI_KEY_FILE=./oci_api_key.pem
# Passphrase for the private key (leave blank if not encrypted)
OCI_KEY_PASSPHRASE=

# OCI Region where Generative AI is available
# Options: us-ashburn-1, uk-london-1, eu-frankfurt-1, ap-singapore-1, ap-tokyo-1
OCI_REGION=us-chicago-1

# OCI Compartment OCID (where resources are provisioned)
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..aaaa...

# ───────────────────────────────────────────────────────────────────
# OCI GENERATIVE AI — LLM
# ───────────────────────────────────────────────────────────────────
OCI_GENAI_LLM_MODEL=cohere.command-r-plus-08-2024
OCI_GENAI_LLM_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_GENAI_MAX_TOKENS=3000
OCI_GENAI_TEMPERATURE=0.3

# ───────────────────────────────────────────────────────────────────
# OCI GENERATIVE AI — EMBEDDING
# ───────────────────────────────────────────────────────────────────
OCI_GENAI_EMBED_MODEL=cohere.embed-v4.0
OCI_GENAI_EMBED_DIM=1536

# ───────────────────────────────────────────────────────────────────
# OCI PRIVATE AGENT FACTORY (PAF)
# ───────────────────────────────────────────────────────────────────

# PAF Runtime base URL
#PAF_BASE_URL=https://agent-runtime.generativeai.ap-singapore-1.oci.oraclecloud.com/20240531

# Per-scenario Agent OCIDs (from OCI Console > AI Services > Agents)
# Set to 'true' to call real PAF endpoint, 'false' to use GenAI fallback
PAF_ENABLED=true
PAF_BASE_URL=
PAF_AGENT_MATURITY=
PAF_AGENT_RECOMMENDATION=
PAF_AGENT_CAMPAIGN=
PAF_AGENT_ALERT=
PAF_AGENT_COPILOT=
PAF_AUTH_USER=
PAF_AUTH_PASS=

# ───────────────────────────────────────────────────────────────────
# PAF AI STUDIO — Alert Analysis Agent with Oracle DB MCP Server
# ───────────────────────────────────────────────────────────────────
# Set PAF_MCP_ENABLED=true ONLY after completing PAF AI Studio setup
# (see database/agent_tools/PAF_Studio_Guidelines_PAF_AGENT_ALERT_MCP.docx)
PAF_MCP_ENABLED=false

# Base URL of PAF AI Studio server (host:port — same server as PAF_BASE_URL)
PAF_MCP_AGENT_ENDPOINT=

# Agent ID for the MCP-enabled alert analysis agent
# → From PAF AI Studio UI: My Agents > PAF_AGENT_ALERT > Copy Agent ID
PAF_MCP_AGENT_ID=

# Auth credentials are shared: PAF_AUTH_USER / PAF_AUTH_PASS (defined above)

# ── Oracle DB connection info for PAF Studio MCP server configuration ──
# (Copy these values into PAF AI Studio > MCP Server > Oracle Database)
PAF_MCP_DB_WALLET_DIR=/path/to/wallet
PAF_MCP_DB_CONNECT_STRING=
PAF_MCP_DB_USER=
PAF_MCP_DB_PASSWORD=
PAF_MCP_DB_SCHEMA=

# ───────────────────────────────────────────────────────────────────
# SMTP — Email Digest (Nodemailer)
# ───────────────────────────────────────────────────────────────────
# Provider examples:
#   Gmail  : SMTP_HOST=smtp.gmail.com   SMTP_PORT=587  SMTP_SECURE=false
#   Office : SMTP_HOST=smtp.office365.com SMTP_PORT=587 SMTP_SECURE=false
#   SES    : SMTP_HOST=email-smtp.<region>.amazonaws.com SMTP_PORT=465 SMTP_SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ───────────────────────────────────────────────────────────────────
# OCI NOTIFICATION SERVICE (ONS)
# Push notifications to email/Slack/HTTPS subscriptions via OCI Topics
# ───────────────────────────────────────────────────────────────────
# Enable OCI ONS: set to true once topic & subscriptions are configured
OCI_NOTIFICATION_ENABLED=false
# ONS Topic OCID (from OCI Console > Application Integration > Notifications)
OCI_NOTIFICATION_TOPIC_ID=
# ONS Publish endpoint (use region-specific URL)
OCI_NOTIFICATION_ENDPOINT=
