<mxCell id="13" value="&lt;b&gt;Market Event&lt;/b&gt;&lt;br/&gt;External market feed&lt;br/&gt;or MARKET_DATA insert&lt;br/&gt;(volatility spike)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="290" y="108" width="200" height="80" as="geometry"/></mxCell>
<mxCell id="14" value="&lt;b&gt;KYC Expiry Scan&lt;/b&gt;&lt;br/&gt;Scheduler: Daily 06:00 WIB&lt;br/&gt;KYC_EXPIRY_DATE ≤ 30 days" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="520" y="108" width="200" height="80" as="geometry"/></mxCell>
<mxCell id="15" value="&lt;b&gt;Idle Money Detection&lt;/b&gt;&lt;br/&gt;Scheduler: Weekly Mon&lt;br/&gt;Large balance in TABUNGAN&lt;br/&gt;with low return &gt; 90 days" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="750" y="108" width="200" height="80" as="geometry"/></mxCell>
<mxCell id="16" value="&lt;b&gt;Concentration Risk&lt;/b&gt;&lt;br/&gt;Scheduler: Monthly&lt;br/&gt;Single asset &gt; 50%&lt;br/&gt;of total portfolio" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="980" y="108" width="200" height="80" as="geometry"/></mxCell>
