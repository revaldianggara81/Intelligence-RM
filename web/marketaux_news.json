{
  "swagger": "2.0",
  "info": {
    "title": "Marketaux Financial News API",
    "description": "Berita keuangan dan saham dari Marketaux untuk Relationship Manager Bank Danamon. Support ticker IDX Indonesia seperti BBCA, BBRI, BMRI, TLKM, BDMN.",
    "version": "1.0.0",
    "contact": {
      "name": "Marketaux Support",
      "url": "https://www.marketaux.com/documentation"
    }
  },
  "host": "api.marketaux.com",
  "basePath": "/",
  "schemes": ["https"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "ApiTokenQuery": {
      "type": "apiKey",
      "name": "api_token",
      "in": "query",
      "description": "Marketaux API token. Daftar gratis di https://www.marketaux.com/register"
    }
  },
  "paths": {
    "/v1/news/all": {
      "get": {
        "operationId": "getMarketNews",
        "summary": "Ambil berita keuangan dan saham",
        "description": "Mengambil berita keuangan terkini dari Marketaux dengan filter berdasarkan ticker saham, sentimen, bahasa, dan negara. Support ticker IDX Indonesia.",
        "tags": ["News"],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "GgXAof7TnNHGLDpYkf3hKm2MOth3ksJRijQWC4ha",
            "description": "Marketaux API token. Daftar gratis di https://www.marketaux.com/register lalu ganti nilai ini."
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Keyword pencarian bebas dalam judul dan isi berita. Gunakan untuk topik yang tidak punya ticker: 'rupiah dollar kurs', 'IHSG bursa saham', 'BI Rate suku bunga', 'inflasi ekonomi Indonesia'. Jangan gunakan bersamaan dengan symbols."
          },
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Ticker saham yang ingin dicari beritanya. Format IDX Indonesia: BBCA.IDX, BBRI.IDX, BMRI.IDX, BDMN.IDX, TLKM.IDX. Format US: AAPL, JPM, MSFT. Pisahkan dengan koma untuk beberapa ticker: BBCA.IDX,BBRI.IDX. Jangan gunakan bersamaan dengan search."
          },
          {
            "name": "filter_entities",
            "in": "query",
            "required": false,
            "type": "boolean",
            "default": true,
            "description": "Filter berita hanya yang benar-benar menyebut ticker. Set true untuk hasil lebih relevan."
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "id,en",
            "enum": ["id", "en", "id,en", "en,id"],
            "description": "Bahasa berita. id=Indonesia, en=Inggris, id,en=keduanya."
          },
          {
            "name": "countries",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "id",
            "description": "Kode negara sumber berita. id=Indonesia, us=Amerika, sg=Singapura. Pisahkan koma: id,us,sg"
          },
          {
            "name": "sentiment",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["positive", "neutral", "negative"],
            "description": "Filter berdasarkan sentimen berita: positive (bullish), neutral, negative (bearish)."
          },
          {
            "name": "industries",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "Banks",
              "Financial Services",
              "Insurance",
              "Investment Trusts",
              "Technology",
              "Telecommunications",
              "Energy",
              "Real Estate",
              "Consumer Goods",
              "Healthcare",
              "Industrials",
              "Materials",
              "Utilities"
            ],
            "description": "Filter berdasarkan industri. Banks untuk perbankan (BCA, BRI, Mandiri, Danamon), Technology untuk TLKM, Financial Services untuk multifinance."
          },
          {
            "name": "published_after",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Filter berita setelah tanggal tertentu. Format: YYYY-MM-DDTHH:MM:SS. Contoh: 2026-06-01T00:00:00"
          },
          {
            "name": "published_before",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Filter berita sebelum tanggal tertentu. Format: YYYY-MM-DDTHH:MM:SS."
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "published_at",
            "enum": ["published_at", "entity_match_score", "relevance_score"],
            "description": "Urutan hasil: published_at (terbaru), entity_match_score (kecocokan ticker), relevance_score (relevansi)."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 5,
            "minimum": 1,
            "maximum": 50,
            "description": "Jumlah berita yang dikembalikan. Default 5, maksimum 50."
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 1,
            "description": "Halaman hasil. Gunakan untuk pagination jika ingin berita lebih lama."
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar berita keuangan berhasil diambil.",
            "schema": {
              "type": "object",
              "properties": {
                "meta": {
                  "type": "object",
                  "properties": {
                    "found": {"type": "integer", "description": "Total berita ditemukan"},
                    "returned": {"type": "integer", "description": "Jumlah berita dikembalikan"},
                    "limit": {"type": "integer"},
                    "page": {"type": "integer"}
                  }
                },
                "data": {
                  "type": "array",
                  "description": "Array berita keuangan",
                  "items": {
                    "type": "object",
                    "properties": {
                      "uuid": {"type": "string"},
                      "title": {"type": "string", "description": "Judul berita"},
                      "description": {"type": "string", "description": "Deskripsi singkat berita"},
                      "snippet": {"type": "string", "description": "Kutipan berita"},
                      "url": {"type": "string", "description": "URL berita lengkap"},
                      "image_url": {"type": "string"},
                      "published_at": {"type": "string", "description": "Waktu publikasi ISO 8601"},
                      "source": {"type": "string", "description": "Domain sumber berita"},
                      "relevance_score": {"type": "number"},
                      "entities": {
                        "type": "array",
                        "description": "Entitas yang disebutkan dalam berita (ticker, perusahaan)",
                        "items": {
                          "type": "object",
                          "properties": {
                            "symbol": {"type": "string", "description": "Ticker saham"},
                            "name": {"type": "string", "description": "Nama perusahaan"},
                            "exchange": {"type": "string"},
                            "exchange_long": {"type": "string"},
                            "country": {"type": "string"},
                            "type": {"type": "string"},
                            "industry": {"type": "string"},
                            "match_score": {"type": "number"},
                            "sentiment_score": {"type": "number", "description": "Sentimen -1 (bearish) sampai 1 (bullish)"},
                            "highlights": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "highlight": {"type": "string"},
                                  "sentiment": {"type": "number"},
                                  "highlighted_in": {"type": "string"}
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "API token tidak valid atau expired.",
            "schema": {"type": "object", "properties": {"error": {"type": "object"}}}
          },
          "429": {
            "description": "Rate limit tercapai. Free tier: 100 request/hari.",
            "schema": {"type": "object", "properties": {"error": {"type": "object"}}}
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "News",
      "description": "Endpoint berita keuangan dan saham"
    }
  ]
}
