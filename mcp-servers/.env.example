# Oracle Autonomous Database (IRMDB) connection
DB_USER=
DB_PASSWORD=
WALLET_PASSWORD=
# One of: irmdb_high | irmdb_medium | irmdb_low | irmdb_tp | irmdb_tpurgent
DB_DSN=irmdb_tp
WALLET_LOCATION=/path/to/wallet

# Oracle Select AI profile used by the Universal Copilot agent for
# free-form natural language -> SQL questions (DBMS_CLOUD_AI)
SELECT_AI_PROFILE=

# SSE (MCP) server hosts/ports for each PAF agent MCP server
MCP_HOST=0.0.0.0
AGENT_MATURITY_PORT=9011
AGENT_RECOMMENDATION_PORT=9012
AGENT_CAMPAIGN_PORT=9013
AGENT_ALERT_PORT=9014
AGENT_COPILOT_PORT=9015
AGENT_YAHOO_PORT=9016
